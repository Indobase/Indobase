# macOS resource forks (avoid xattr errors when building on Docker Desktop)
._*
**/._*

# VCS
.git
**/.git
.gitignore

# Node and build artifacts
node_modules
.pnpm-store

# Build outputs
**/dist
**/build
**/.next
**/.turbo

# IDE files
.vscode
.idea
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Logs
*.log
logs

# Test files
**/*.test.*
**/*.spec.*
coverage

# Git
.git
.gitignore

# Docker
Dockerfile
docker-compose.yml
.dockerignore

# CI/CD
.github

# Documentation
*.md
docs

# Temporary files
tmp
temp
*.tmp

# Environment files
.env*
!.env.example

# Package manager files
package-lock.json
yarn.lock

# Studio needs packages/ui/build (theme CSS) at build time — do not exclude
!packages/ui/build

