# --- Indobase wiring (single domain: indobase.fun) ---
# Console / Studio URL. Use same-domain /dashboard (not console.indobase.fun). Local dev: http://localhost:3000
PUBLIC_APPWRITE_DASHBOARD=https://indobase.fun/dashboard
# Alternative: PUBLIC_INDOBASE_CONSOLE_URL. "Start building" CTAs link to this base + /sign-up

# Backend API (same domain). Production: indobase.fun/api. Local: your backend URL
PUBLIC_APPWRITE_ENDPOINT=https://indobase.fun/api/v1
PUBLIC_APPWRITE_PROJECT_ID=demo

# --- Appwrite/legacy (optional) ---
PUBLIC_APPWRITE_COL_MESSAGES_ID=
PUBLIC_APPWRITE_COL_THREADS_ID=
PUBLIC_APPWRITE_DB_MAIN_ID=
PUBLIC_APPWRITE_FN_TLDR_ID=
PUBLIC_APPWRITE_PROJECT_INIT_ID=
PUBLIC_GROWTH_ENDPOINT=
PUBLIC_POSTHOG_API_KEY=
APPWRITE_DB_INIT_ID=
APPWRITE_COL_INIT_ID=
APPWRITE_API_KEY_INIT=
SENTRY_AUTH_TOKEN=
